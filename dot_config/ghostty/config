font-family = UDEV Gothic 35NFLG
font-size = 12

theme = catppuccin-mocha

cursor-style = bar
cursor-style-blink = false

window-padding-x = 4
window-padding-y = 4
window-decoration = false

copy-on-select = clipboard
confirm-close-surface = false

keybind = ctrl+shift+equal=increase_font_size:2
keybind = ctrl+shift+minus=decrease_font_size:2
keybind = ctrl+shift+backspace=reset_font_size
