{
  "hyprland/workspaces": {
    "disable-scroll": true,
    "all-outputs": true,
    "warp-on-scroll": false,
    "format": "{name} {icon}",
    "format-icons": {
      "1": "󰖟",
      "2": "󰨞",
      "3": "󰍦",
      "4": "󰍹",
      "5": "󰉋",
      "urgent": "󰗖",
      "focused": "󰮯",
      "default": "󰊠"
    }
  },
  "hyprland/submap": {
    "format": "   {} ",
    "tooltip": false
  },
  "hyprland/window": {
    "format": "  {}",
    "icon": true,
    "max-length": 60,
    "separate-outputs": true
  },
  "cpu": {
    "interval": 2,
    "format": "󰻠 {usage}%",
    "tooltip": true,
    "tooltip-format": "CPU Usage: {usage}%\nLoad: {load}"
  },
  "memory": {
    "interval": 2,
    "format": "󰍛 {percentage}%",
    "tooltip": true,
    "tooltip-format": "Memory: {used:0.1f}G/{total:0.1f}G ({percentage}%)\nSwap: {swapUsed:0.1f}G/{swapTotal:0.1f}G"
  },
  "disk": {
    "interval": 30,
    "format": "󰋊 {percentage_used}%",
    "path": "/",
    "tooltip": true,
    "tooltip-format": "Disk Usage: {used}/{total} ({percentage_used}%)\nAvailable: {free}"
  },
  "clock": {
    "interval": 1,
    "format": "󰥔 {:%Y/%m/%d %H:%M:%S}",
    "format-alt": "󰃭 {:%Y年%m月%d日 (%a)}",
    "tooltip-format": "<big>{:%Y年 %B}</big>\n<tt><small>{calendar}</small></tt>"
  },
  "user": {
    "format": " {work_d}:{work_H}:{work_M}"
  },
  "network": {
    "interval": 2,
    "interface": "wlp2s0",
    "format-wifi": "󰖩 {signalStrength}% 󰇚{bandwidthDownBytes:>7} 󰕒{bandwidthUpBytes:>7}",
    "format-ethernet": "󰌗 󰇚{bandwidthDownBytes:>7} 󰕒{bandwidthUpBytes:>7}",
    "format-linked": "󰌘 No IP",
    "format-disconnected": "󰌙 Disconnected",
    "tooltip": true,
    "tooltip-format-wifi": "Interface: {ifname}\nSSID: {essid}\nSignal: {signalStrength}%\nFrequency: {frequency}MHz\nIP: {ipaddr}/{cidr}\nGateway: {gwaddr}\n↓ {bandwidthDownBytes}/s ↑ {bandwidthUpBytes}/s",
    "tooltip-format-ethernet": "Interface: {ifname}\nIP: {ipaddr}/{cidr}\nGateway: {gwaddr}\n↓ {bandwidthDownBytes}/s ↑ {bandwidthUpBytes}/s",
    "on-click": "nm-connection-editor"
  },
  "bluetooth": {
    "format": "󰂯",
    "format-on": "󰂲",
    "format-off": "󰂲",
    "format-disabled": "󰂲",
    "format-connected": "󰂱 {num_connections}",
    "format-connected-battery": "󰂱 {device_battery_percentage}%",
    "tooltip": true,
    "tooltip-format": "Bluetooth {status}",
    "tooltip-format-connected": "Connected: {num_connections} device(s){device_enumerate}",
    "tooltip-format-enumerate-connected": "• {device_alias} ({device_address})",
    "tooltip-format-enumerate-connected-battery": "• {device_alias} ({device_address}) - {device_battery_percentage}%",
    "on-click": "blueman-manager"
  },
  "wireplumber": {
    "format": "󰕾 {volume}%",
    "format-muted": "󰖁 Muted",
    "tooltip": true,
    "tooltip-format": "Audio: {node_name} Volume: {volume}%",
    "on-click": "helvum",
    "on-click-right": "pavucontrol",
    "max-volume": 150,
    "scroll-step": 5
  },
  "custom/weather": {
    "format": "󰖐 {}°",
    "tooltip": true,
    "interval": 1800,
    "exec": "wttrbar --location yokohama --lang ja",
    "return-type": "json"
  },
  "custom/updates": {
    "format": "󰏖 {} {icon}",
    "return-type": "json",
    "format-icons": {
      "has-updates": "󱍷",
      "updated": "󰂪"
    },
    "exec-if": "which waybar-module-pacman-updates",
    "exec": "waybar-module-pacman-updates --interval-seconds 900 --network-interval-seconds 3600",
    "on-click": "ghostty -e yay -Syu"
  },
  "custom/topproc": {
    "interval": 2,
    "format": "󰻠 {:>18}",
    "exec-on-event": true,
    "return-type": "json",
    "exec": "~/.config/waybar/topproc.sh"
  },
  "custom/uptime": {
    "interval": 60,
    "format": "󰅐 {:>8}",
    "exec": "awk '{days=int($1/86400); hours=int(($1%86400)/3600); mins=int(($1%3600)/60); printf \"%d:%02d:%02d\", days*24+hours, mins, int($1%60)}' /proc/uptime",
    "tooltip": true,
    "tooltip-format": "System Uptime: {}"
  },
  "custom/display": {
    "format": "󰍹 ",
    "tooltip": "Display Manager - Click to refresh displays",
    "on-click": "~/.config/waybar/reflesh-display.sh"
  },
  "tray": {
    "icon-size": 24
  }
}
