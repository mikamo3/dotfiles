{{- if eq .chezmoi.hostname "mainpc" -}}
# ----------------------------------------------------------------
# モニタ配置設定 (スケール 1.25 最適化版)
# ----------------------------------------------------------------

# 1. 左: I-O Data EX-LDGCU271D (縦置き)
# 変更点: scale 1.5 -> 1.25
# 計算: 物理短辺2160 / 1.25 = 論理幅 1728px
monitor = HDMI-A-2, 3840x2160@60, 0x0, 1.25, transform, 3, bitdepth, 8

# 2. 中央: LG UltraWide (横置き)
# 変更点: 位置を 1440 -> 1728 に変更 (左モニタの幅が増えたため)
monitor = HDMI-A-1, 3440x1440@60, 1728x0, 1


# 3. 右: モバイルモニタ (縦置き)
# 変更点: 位置を 4880 -> 5168 に変更
# 計算: 左(1728) + 中央(3440) = 5168
monitor = DP-1, 2560x1600@60, 5168x0, 1.333333, transform, 1

# 未接続時のフォールバック
monitor = , preferred, auto, 1

{{- else }}
# TODO: {{ .chezmoi.hostname }} 用のモニター設定を追加してください
monitor = ,preferred,auto,1
{{- end }}
